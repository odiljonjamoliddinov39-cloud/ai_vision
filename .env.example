# Copy to .env on the Droplet and edit values there. Do not commit real secrets.
AI_VISION_PORT=8080

# Set DATABASE_URL for PostgreSQL. If empty, local SQLite files under ./database are used.
# DATABASE_URL=postgresql://ai_vision:change-me@postgres:5432/ai_vision

AUTO_START_DETECTION=true
DETECTION_WATCHDOG_ENABLED=true
DETECTION_WATCHDOG_INTERVAL_SECONDS=30

# Optional security/configuration
# ADMIN_API_KEY=
# PUBLIC_DASHBOARD_URL=https://your-vercel-domain.vercel.app
# ALLOWED_ORIGINS=https://your-domain.com,http://SERVER_IP:8080
# WEBAUTHN_ALLOWED_ORIGINS=https://your-domain.com,http://SERVER_IP:8080
# WEBAUTHN_RP_NAME=AI Vision
